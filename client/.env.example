# Enviroment variables needed to connect to the LiveKit server.
LIVEKIT_API_KEY="<your_api_key>"
LIVEKIT_API_SECRET="<your_api_secret>"
LIVEKIT_URL="wss://<project-subdomain>.livekit.cloud"

# Infura Secrets for IPFS Upload (required only when Zora minting is enabled)
INFURA_API_KEY=""
INFURA_API_SECRET=""

# Reown AppKit Project ID (required only when Zora minting is enabled)
NEXT_PUBLIC_PROJECT_ID=""

# Set to "false" to disable Zora minting flow (hides wallet connect + coin button)
NEXT_PUBLIC_ENABLE_ZORA_MINTING=true
